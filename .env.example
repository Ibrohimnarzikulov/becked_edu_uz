# Django
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
# In Docker, DB_HOST must be the compose service name (db, see docker-compose.yml).
# For local dev without Docker, use localhost.
DB_NAME=eduhub
DB_USER=eduhub_user
DB_PASSWORD=eduhub_pass_2026
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# CORS
CORS_ALLOW_ALL=True

# i18n default
DEFAULT_LANGUAGE=uz

# Production security (only when behind HTTPS reverse proxy)
# SECURE_SSL_REDIRECT=False
# SECURE_PROXY_SSL_HEADER=False
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True